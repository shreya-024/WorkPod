PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/workpilot?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_here
GEMINI_MODEL=gemini-2.5-flash
CLIENT_URL=http://localhost:5173

# ─── Gemini API Keys ──────────────────────────────────────────────────────────
# Supply multiple keys for automatic round-robin rotation and quota failover.
# The service reads these env vars in order; any that are set will be used.
# If none of the numbered keys are set, it falls back to GEMINI_KEY.
GEMINI_KEY=your_gemini_api_key_here
GEMINI_KEY_1=
GEMINI_KEY_2=
GEMINI_KEY_3=
gemini_key_4=
geminikey5=
gemini_key_6=
